# Vidya Chinthana — copy to `.env` and adjust (never commit `.env`)

# --- Local dev server ---
PORT=3000

# --- Google Gemini (CMS AI — optional) ---
GEMINI_API_KEY=

# --- Supabase (production DB; omit for JSON fallback in data_db/) ---
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=
# Server / Netlify Functions only — never expose in Vite or browser
SUPABASE_SERVICE_ROLE_KEY=

# --- Vite (browser — optional direct Supabase reads via RLS) ---
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=

# --- Netlify (optional) ---
# NETLIFY_ENABLE_UPLOADS=true

# --- Legacy / future ---
# VC_SESSION_SECRET=generate-a-long-random-string
